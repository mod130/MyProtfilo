# Copy this file to .env and fill in your own values.

# Optional: a form backend endpoint (e.g. https://formspree.io/f/xxxxxxx,
# or your own serverless function) that accepts a POST request with
# JSON body { name, email, subject, message }.
# If left empty, the contact form falls back to opening the visitor's
# email client with the message pre-filled (mailto), so the site works
# with zero backend configuration.
VITE_CONTACT_ENDPOINT=

# Where the "mailto" fallback should be sent.
VITE_CONTACT_EMAIL=Mohalhartoumi@gmail.com
